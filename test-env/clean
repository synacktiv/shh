#!/bin/bash -eu

if [ $# -ne 1 ]
then
    echo "Usage: $0 DISTRIBUTION" >&2
    echo "Environment: TARGET_DIR (default: <repo>/test-env/target/<distribution>)" >&2
    exit 1
fi

readonly DISTRIBUTION="${1:?}"
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
readonly PROJECT_DIR
readonly TARGET_DIR="${TARGET_DIR:-${PROJECT_DIR}/test-env/target/${DISTRIBUTION}}"

sudo rm -Rf "${TARGET_DIR}"
